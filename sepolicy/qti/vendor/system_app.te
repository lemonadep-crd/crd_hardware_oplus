# Battery Health
r_dir_file(system_app, vendor_sysfs_usb_supply)

# LTPO Settings
rw_dir_file(system_app, vendor_sysfs_graphics)

# Gamespace
r_dir_file(system_app, vendor_sysfs_sde_crtc)

# Touchpanel
rw_dir_file(system_app, vendor_proc_display)

# PowerTools - CPU frequency/governor control
allow system_app sysfs_devices_system_cpu:dir r_dir_perms;
allow system_app sysfs_devices_system_cpu:{ file lnk_file } rw_file_perms;

# PowerTools - GPU frequency control
allow system_app sysfs_kgsl_gpuclk:dir r_dir_perms;
allow system_app sysfs_kgsl_gpuclk:{ file lnk_file } rw_file_perms;

# Battery temp reading
allow system_app vendor_sysfs_battery_supply:dir search;
allow system_app vendor_sysfs_battery_supply:file r_file_perms;

# Thermal zone reading
allow system_app sysfs_thermal_powertools:dir r_dir_perms;
allow system_app sysfs_thermal_powertools:{ file lnk_file } r_file_perms;

# cgroup access
allow system_app cgroup:dir search;

set_prop(system_app, exported_system_prop)

# USB fast charge
rw_dir_file(system_app, vendor_sysfs_fastcharge)

# Vibrator
rw_dir_file(system_app, sysfs_vibrator)

# Zram
r_dir_file(system_app, sysfs_zram)

# System Monitor Widget - /proc/stat (CPU usage)
allow system_app proc_stat:file { read open getattr };

# System Monitor Widget - GPU devfreq cur_freq/max_freq
allow system_app vendor_sysfs_kgsl:dir r_dir_perms;
allow system_app vendor_sysfs_kgsl:{ file lnk_file } r_file_perms;

# System Monitor Widget - /proc/meminfo (swap stats)
allow system_app proc_meminfo:file { read open getattr };

# Binder calls to HALs
allow system_app hal_audio_default:binder call;
allow system_app hal_bootctl_default:binder call;
allow system_app hal_health_default:binder call;
allow system_app hal_memtrack_default:binder call;
allow system_app hal_nfc_default:binder call;
allow system_app hal_power_default:binder call;
allow system_app hal_sensors_default:binder call;
allow system_app hal_thermal_default:binder call;
allow system_app vendor_hal_usb_qti:binder call;
